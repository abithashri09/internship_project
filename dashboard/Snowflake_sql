CREATE SCHEMA IF NOT EXISTS SILVER;

CREATE OR REPLACE TABLE SILVER.ORDER_DATASET_CLEAN AS
SELECT
    ORDER_ID,
    CUSTOMER_ID,
    ORDER_STATUS,
    ORDER_PURCHASE_TIMESTAMP,
    COALESCE(ORDER_APPROVED_AT, '1900-01-01'::TIMESTAMP) AS ORDER_APPROVED_AT,
    COALESCE(ORDER_DELIVERED_CARRIER_DATE, '1900-01-01'::TIMESTAMP) AS ORDER_DELIVERED_CARRIER_DATE,
    COALESCE(ORDER_DELIVERED_CUSTOMER_DATE, '1900-01-01'::TIMESTAMP) AS ORDER_DELIVERED_CUSTOMER_DATE,
    ORDER_ESTIMATED_DELIVERY_DATE
FROM BRONZE.ORDER_DATASET;

SELECT *
FROM SILVER.ORDER_DATASET_CLEAN
LIMIT 10;

SELECT
    COUNT_IF(ORDER_APPROVED_AT IS NULL),
    COUNT_IF(ORDER_DELIVERED_CARRIER_DATE IS NULL),
    COUNT_IF(ORDER_DELIVERED_CUSTOMER_DATE IS NULL)
FROM SILVER.ORDER_DATASET_CLEAN;
SELECT
    COUNT_IF(ORDER_APPROVED_AT IS NULL),
    COUNT_IF(ORDER_DELIVERED_CARRIER_DATE IS NULL),
    COUNT_IF(ORDER_DELIVERED_CUSTOMER_DATE IS NULL)
FROM SILVER.ORDER_DATASET_CLEAN;
CREATE OR REPLACE TABLE SILVER.ORDER_REVIEW_CLEAN AS
SELECT
    REVIEW_ID,
    ORDER_ID,
    REVIEW_SCORE,
    COALESCE(REVIEW_COMMENT_TITLE, 'No Title') AS REVIEW_COMMENT_TITLE,
    COALESCE(REVIEW_COMMENT_MESSAGE, 'No Review') AS REVIEW_COMMENT_MESSAGE,
    REVIEW_CREATION_DATE,
    REVIEW_ANSWER_TIMESTAMP
FROM BRONZE.ORDER_REVIEW;

SELECT
    COUNT_IF(REVIEW_COMMENT_TITLE IS NULL) AS TITLE_NULLS,
    COUNT_IF(REVIEW_COMMENT_MESSAGE IS NULL) AS MESSAGE_NULLS
FROM SILVER.ORDER_REVIEW_CLEAN;
CREATE OR REPLACE TABLE SILVER.PRODUCT_CLEAN AS
SELECT
    PRODUCT_ID,
    COALESCE(PRODUCT_CATEGORY_NAME, 'Unknown') AS PRODUCT_CATEGORY_NAME,
    COALESCE(PRODUCT_NAME_LENGHT, 0) AS PRODUCT_NAME_LENGHT,
    COALESCE(PRODUCT_DESCRIPTION_LENGHT, 0) AS PRODUCT_DESCRIPTION_LENGHT,
    COALESCE(PRODUCT_PHOTOS_QTY, 0) AS PRODUCT_PHOTOS_QTY,
    COALESCE(PRODUCT_WEIGHT_G, 0) AS PRODUCT_WEIGHT_G,
    COALESCE(PRODUCT_LENGTH_CM, 0) AS PRODUCT_LENGTH_CM,
    COALESCE(PRODUCT_HEIGHT_CM, 0) AS PRODUCT_HEIGHT_CM,
    COALESCE(PRODUCT_WIDTH_CM, 0) AS PRODUCT_WIDTH_CM
FROM BRONZE.PRODUCT;
SELECT
    COUNT_IF(PRODUCT_CATEGORY_NAME IS NULL) AS CATEGORY_NULLS,
    COUNT_IF(PRODUCT_NAME_LENGHT IS NULL) AS NAME_NULLS,
    COUNT_IF(PRODUCT_DESCRIPTION_LENGHT IS NULL) AS DESCRIPTION_NULLS,
    COUNT_IF(PRODUCT_PHOTOS_QTY IS NULL) AS PHOTO_NULLS,
    COUNT_IF(PRODUCT_WEIGHT_G IS NULL) AS WEIGHT_NULLS,
    COUNT_IF(PRODUCT_LENGTH_CM IS NULL) AS LENGTH_NULLS,
    COUNT_IF(PRODUCT_HEIGHT_CM IS NULL) AS HEIGHT_NULLS,
    COUNT_IF(PRODUCT_WIDTH_CM IS NULL) AS WIDTH_NULLS
FROM SILVER.PRODUCT_CLEAN;
CREATE OR REPLACE TABLE GOLD.DIM_CUSTOMER AS
SELECT
    ROW_NUMBER() OVER (ORDER BY CUSTOMER_ID) AS CUSTOMER_KEY,
    CUSTOMER_ID,
    CUSTOMER_UNIQUE_ID,
    CUSTOMER_CITY,
    CUSTOMER_STATE
FROM BRONZE.CUSTOMER;

CREATE OR REPLACE TABLE GOLD.DIM_PRODUCT AS
SELECT
    ROW_NUMBER() OVER (ORDER BY PRODUCT_ID) AS PRODUCT_KEY,
    PRODUCT_ID,
    PRODUCT_CATEGORY_NAME,
    PRODUCT_WEIGHT_G,
    PRODUCT_LENGTH_CM,
    PRODUCT_HEIGHT_CM,
    PRODUCT_WIDTH_CM
FROM SILVER.PRODUCT_CLEAN;
CREATE OR REPLACE TABLE GOLD.DIM_SELLER AS
SELECT
    ROW_NUMBER() OVER (ORDER BY SELLER_ID) AS SELLER_KEY,
    SELLER_ID,
    SELLER_CITY,
    SELLER_STATE
FROM BRONZE.ORDER_SELLER;
CREATE OR REPLACE TABLE GOLD.DIM_REVIEW AS
SELECT
    ROW_NUMBER() OVER (ORDER BY REVIEW_ID) AS REVIEW_KEY,
    REVIEW_ID,
    REVIEW_SCORE,
    REVIEW_COMMENT_TITLE,
    REVIEW_COMMENT_MESSAGE
FROM SILVER.ORDER_REVIEW_CLEAN;

CREATE OR REPLACE TABLE GOLD.FACT_SALES AS
SELECT
    o.ORDER_ID,

    dc.CUSTOMER_KEY,
    dp.PRODUCT_KEY,
    ds.SELLER_KEY,
    dr.REVIEW_KEY,

    oi.PRICE,
    oi.FREIGHT_VALUE,
    op.PAYMENT_VALUE,

    o.ORDER_STATUS,
    o.ORDER_PURCHASE_TIMESTAMP

FROM SILVER.ORDER_DATASET_CLEAN o

LEFT JOIN BRONZE.ORDER_ITEMS oi
    ON o.ORDER_ID = oi.ORDER_ID

LEFT JOIN BRONZE.ORDER_PAYMENTS op
    ON o.ORDER_ID = op.ORDER_ID

LEFT JOIN GOLD.DIM_CUSTOMER dc
    ON o.CUSTOMER_ID = dc.CUSTOMER_ID

LEFT JOIN GOLD.DIM_PRODUCT dp
    ON oi.PRODUCT_ID = dp.PRODUCT_ID

LEFT JOIN GOLD.DIM_SELLER ds
    ON oi.SELLER_ID = ds.SELLER_ID

LEFT JOIN SILVER.ORDER_REVIEW_CLEAN r
    ON o.ORDER_ID = r.ORDER_ID

LEFT JOIN GOLD.DIM_REVIEW dr
    ON r.REVIEW_ID = dr.REVIEW_ID;
SELECT SUM(PAYMENT_VALUE)
FROM GOLD.FACT_SALES;

SELECT AVG(REVIEW_SCORE)
FROM GOLD.DIM_REVIEW;
 
SELECT COUNT(DISTINCT ORDER_ID)
FROM GOLD.FACT_SALES;


SELECT DISTINCT PAYMENT_TYPE
FROM ECOMMERCE_LISTS.BRONZE.ORDER_PAYMENTS;

CREATE OR REPLACE VIEW GOLD.PROFIT_ANALYSIS AS
SELECT
    ORDER_ID,
    PAYMENT_VALUE AS REVENUE,
    ROUND(PAYMENT_VALUE * 0.80,2) AS ESTIMATED_COST,
    ROUND(PAYMENT_VALUE * 0.20,2) AS ESTIMATED_PROFIT
FROM BRONZE.ORDER_PAYMENTS;

