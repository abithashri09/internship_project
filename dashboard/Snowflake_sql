CREATE OR REPLACE VIEW GOLD.PROFIT_ANALYSIS AS
SELECT
    p.order_id,
    o.order_purchase_timestamp,
    p.payment_type,
    p.payment_value AS Revenue,
    ROUND(p.payment_value * 0.80,2) AS Estimated_Cost,
